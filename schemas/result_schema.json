{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evaluation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_name",
    "model",
    "generated_at",
    "summary",
    "results"
  ],
  "properties": {
    "run_name": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_samples",
        "accuracy",
        "per_label"
      ],
      "properties": {
        "total_samples": {
          "type": "integer",
          "minimum": 0
        },
        "accuracy": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "per_label": {
          "type": "object",
          "propertyNames": {
            "enum": [
              "phishing",
              "impersonation",
              "benign"
            ]
          },
          "additionalProperties": {
            "$ref": "#/$defs/label_stats"
          }
        },
        "classification_metrics": {
          "$ref": "#/$defs/classification_metrics"
        },
        "confusion_matrix": {
          "$ref": "#/$defs/confusion_matrix"
        },
        "explanation_support": {
          "$ref": "#/$defs/explanation_support"
        },
        "llm": {
          "$ref": "#/$defs/llm_summary"
        }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/result_item"
      }
    }
  },
  "$defs": {
    "label_name": {
      "type": "string",
      "enum": [
        "phishing",
        "impersonation",
        "benign"
      ]
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "nullable_number": {
      "type": [
        "number",
        "null"
      ]
    },
    "nullable_integer": {
      "type": [
        "integer",
        "null"
      ]
    },
    "label_stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "tp",
        "fp",
        "fn",
        "precision",
        "recall",
        "f1"
      ],
      "properties": {
        "label": {
          "$ref": "#/$defs/label_name"
        },
        "tp": {
          "type": "integer",
          "minimum": 0
        },
        "fp": {
          "type": "integer",
          "minimum": 0
        },
        "fn": {
          "type": "integer",
          "minimum": 0
        },
        "precision": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "recall": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "f1": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "classification_metrics_per_label": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support",
        "precision",
        "recall",
        "f1"
      ],
      "properties": {
        "support": {
          "type": "integer",
          "minimum": 0
        },
        "precision": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "recall": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "f1": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "classification_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accuracy",
        "macro_precision",
        "macro_recall",
        "macro_f1",
        "micro_precision",
        "micro_recall",
        "micro_f1",
        "weighted_precision",
        "weighted_recall",
        "weighted_f1",
        "per_label",
        "labels",
        "total_support"
      ],
      "properties": {
        "accuracy": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "macro_precision": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "macro_recall": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "macro_f1": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "micro_precision": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "micro_recall": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "micro_f1": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "weighted_precision": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "weighted_recall": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "weighted_f1": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "per_label": {
          "type": "object",
          "propertyNames": {
            "enum": [
              "phishing",
              "impersonation",
              "benign"
            ]
          },
          "additionalProperties": {
            "$ref": "#/$defs/classification_metrics_per_label"
          }
        },
        "labels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/label_name"
          }
        },
        "total_support": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "confusion_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "labels",
        "rows"
      ],
      "properties": {
        "labels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/label_name"
          }
        },
        "rows": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "support_example": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_id",
        "actual_label",
        "predicted_label",
        "status",
        "notes"
      ],
      "properties": {
        "sample_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "actual_label": {
          "$ref": "#/$defs/nullable_string"
        },
        "predicted_label": {
          "$ref": "#/$defs/nullable_string"
        },
        "status": {
          "type": "string",
          "enum": [
            "weak",
            "unsupported"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "explanation_support": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supported_count",
        "weak_count",
        "unsupported_count",
        "unavailable_count",
        "examples"
      ],
      "properties": {
        "supported_count": {
          "type": "integer",
          "minimum": 0
        },
        "weak_count": {
          "type": "integer",
          "minimum": 0
        },
        "unsupported_count": {
          "type": "integer",
          "minimum": 0
        },
        "unavailable_count": {
          "type": "integer",
          "minimum": 0
        },
        "examples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/support_example"
          }
        }
      }
    },
    "llm_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "providers",
        "models",
        "llm_call_count",
        "retry_count",
        "total_input_tokens",
        "total_output_tokens",
        "total_tokens",
        "total_cost_usd",
        "total_latency_ms",
        "avg_latency_ms"
      ],
      "properties": {
        "providers": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "models": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "llm_call_count": {
          "type": "integer",
          "minimum": 0
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_cost_usd": {
          "type": "number",
          "minimum": 0.0
        },
        "total_latency_ms": {
          "type": "number",
          "minimum": 0.0
        },
        "avg_latency_ms": {
          "$ref": "#/$defs/nullable_number"
        }
      }
    },
    "result_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_id",
        "actual_label",
        "predicted_label",
        "risk_score",
        "confidence",
        "explanation",
        "signals_json",
        "timeline_json",
        "reliability_run_id",
        "reliability_phase_id",
        "reliability_prompt_id",
        "reliability_call_id",
        "provider",
        "model",
        "latency_ms",
        "input_tokens",
        "output_tokens",
        "token_cost_usd"
      ],
      "properties": {
        "sample_id": {
          "type": "string"
        },
        "actual_label": {
          "$ref": "#/$defs/label_name"
        },
        "predicted_label": {
          "$ref": "#/$defs/label_name"
        },
        "risk_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "explanation": {
          "$ref": "#/$defs/nullable_string"
        },
        "signals_json": {
          "type": [
            "object",
            "null"
          ]
        },
        "timeline_json": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "reliability_run_id": {
          "type": "string"
        },
        "reliability_phase_id": {
          "type": "string"
        },
        "reliability_prompt_id": {
          "type": "string"
        },
        "reliability_call_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "provider": {
          "$ref": "#/$defs/nullable_string"
        },
        "model": {
          "$ref": "#/$defs/nullable_string"
        },
        "latency_ms": {
          "$ref": "#/$defs/nullable_number"
        },
        "input_tokens": {
          "$ref": "#/$defs/nullable_integer"
        },
        "output_tokens": {
          "$ref": "#/$defs/nullable_integer"
        },
        "token_cost_usd": {
          "$ref": "#/$defs/nullable_number"
        },
        "explanation_support_status": {
          "type": "string",
          "enum": [
            "supported",
            "weak",
            "unsupported",
            "unavailable"
          ]
        },
        "explanation_support_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
