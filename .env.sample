# ── Database ──────────────────────────────────────────────────────────────────
# Shared Postgres instance. asyncpg driver required for SQLAlchemy async.
# Both ai-reliability-fw and security-ai-eval-lab point at this same URL.
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/shared_db

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Required for full eval path (evaluation/runner.py without --dry-run).
# Not needed for the quickstart path (examples/run_eval.py).
OPENAI_API_KEY=sk-REPLACE_ME

# ── Eval Runner Defaults ──────────────────────────────────────────────────────
DEFAULT_MODEL=gpt-4o-mini
EVAL_RUN_NAME=eval-local

# ── Docker Postgres ───────────────────────────────────────────────────────────
# Only used when running the bundled db service via docker compose.
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=shared_db

# ── GitHub Release Asset Access ───────────────────────────────────────────────
# GitHub PAT used to fetch ai-reliability-fw wheel from GitHub Release assets.
# Scope needed: repo (classic PAT) — GitHub Packages does not support Python/PyPI.
# Create at: github.com/settings/tokens → "Generate new token (classic)" → check repo
REGISTRY_TOKEN=REPLACE_ME
